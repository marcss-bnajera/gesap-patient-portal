generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PatientAccount {
  id          Int           @id @default(autoincrement())
  dpi         String        @unique @db.VarChar(13)
  email       String        @unique @db.VarChar(100)
  password    String        @db.VarChar(255)
  status      AccountStatus @default(PENDING)
  approvedBy  Int?          @map("approved_by")
  approvedAt  DateTime?     @map("approved_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@map("patient_accounts")
}

enum AccountStatus {
  PENDING
  APPROVED
  REJECTED
}

model Patient {
  id             Int      @id @default(autoincrement())
  dpi            String   @unique @db.VarChar(13)
  firstName      String   @map("first_name") @db.VarChar(50)
  secondName     String?  @map("second_name") @db.VarChar(50)
  thirdName      String?  @map("third_name") @db.VarChar(50)
  firstLastName  String   @map("first_last_name") @db.VarChar(50)
  secondLastName String   @map("second_last_name") @db.VarChar(50)
  birthDate      DateTime @map("birth_date") @db.Date
  sex            String
  bloodType      String?  @map("blood_type")
  phone          String?  @db.VarChar(8)
  address        String?  @db.VarChar(255)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  emergencyContacts EmergencyContact[]

  @@map("patients")
}

model EmergencyContact {
  id           Int      @id @default(autoincrement())
  patientId    Int      @map("patient_id")
  fullName     String   @map("full_name") @db.VarChar(100)
  phone        String   @db.VarChar(8)
  relationship String?  @db.VarChar(50)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id])

  @@map("emergency_contacts")
}
