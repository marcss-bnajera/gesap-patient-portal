// ---- REFERENCIA A PACIENTES (tabla de gesap-api, solo lectura) ----

model Patient {
  id             Int      @id @default(autoincrement())
  dpi            String   @unique @db.VarChar(13)
  firstName      String   @map("first_name") @db.VarChar(50)
  secondName     String?  @map("second_name") @db.VarChar(50)
  thirdName      String?  @map("third_name") @db.VarChar(50)
  firstLastName  String   @map("first_last_name") @db.VarChar(50)
  secondLastName String   @map("second_last_name") @db.VarChar(50)
  birthDate      DateTime @map("birth_date") @db.Date
  sex            String
  bloodType      String?  @map("blood_type")
  phone          String?  @db.VarChar(8)
  address        String?  @db.VarChar(255)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  emergencyContacts EmergencyContact[]

  @@map("patients")
}

// ---- CONTACTOS DE EMERGENCIA (max 5 por paciente) ----
model EmergencyContact {
  id          Int      @id @default(autoincrement())
  patientId   Int      @map("patient_id")
  fullName    String   @map("full_name") @db.VarChar(100)
  phone       String   @db.VarChar(8)
  relationship String? @db.VarChar(50)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id])

  @@map("emergency_contacts")
}