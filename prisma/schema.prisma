// =============================================
// GESAP Patient Portal - Esquema de BD
// Se conecta a la MISMA base de datos que gesap-api
// Agrega tabla patient_accounts para login de pacientes
// =============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- CUENTAS DE PACIENTES ----
// Maneja el autoregistro y aprobacion por auditor
model PatientAccount {
  id          Int      @id @default(autoincrement())
  dpi         String   @unique @db.VarChar(13)
  email       String   @unique @db.VarChar(100)
  password    String   @db.VarChar(255)
  status      AccountStatus @default(PENDING)
  approvedBy  Int?     @map("approved_by")
  approvedAt  DateTime? @map("approved_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("patient_accounts")
}

enum AccountStatus {
  PENDING
  APPROVED
  REJECTED
}

// ---- REFERENCIA A PACIENTES (tabla existente de gesap-api) ----
// Solo lectura desde este servicio
model Patient {
  id               Int      @id @default(autoincrement())
  dpi              String   @unique @db.VarChar(13)
  firstName        String   @map("first_name") @db.VarChar(50)
  lastName         String   @map("last_name") @db.VarChar(50)
  birthDate        DateTime @map("birth_date") @db.Date
  sex              String
  bloodType        String?  @map("blood_type")
  phone            String?  @db.VarChar(8)
  address          String?  @db.VarChar(255)
  emergencyContact String?  @map("emergency_contact") @db.VarChar(100)
  emergencyPhone   String?  @map("emergency_phone") @db.VarChar(8)
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("patients")
}